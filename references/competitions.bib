@article{Bennett2023,
  author = {Bennett, Nathaniel R. and Coventry, Brian and Goreshnik, Inna and Huang, Buwei and Allen, Aza and Vafeados, Dionne and Peng, Ying Po and Dauparas, Justas and Baek, Minkyung and Stewart, Lance and DiMaio, Frank and De Munck, Steven and Savvides, Savvas N. and Baker, David},
  title = {Improving \textit{De Novo} Protein Binder Design with Deep Learning},
  journal = {Nature Communications},
  year = {2023},
  volume = {14},
  pages = {2625},
  doi = {10.1038/s41467-023-38328-5},
  note = {URL: https://www.nature.com/articles/s41467-023-38328-5, accessed 2026-05-06. AF2 \textit{pAE\_interaction} filter raises retrospective binder design success rates ~10-fold; prospective campaigns on ALK, LTK, IL-10R-alpha, IL-2R-alpha sites 1\&2 yield 1-17 binders per 5,000 AF2-filtered designs (8x and 30x higher than physics-only filters), but absolute success rates remain <1\%.}
}

