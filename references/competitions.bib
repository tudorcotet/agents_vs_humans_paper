  title = {Design of Protein-Binding Proteins from the Target Structure Alone},
  journal = {Nature},
  year = {2022},
  volume = {605},
  number = {7910},
  pages = {551--560},
  doi = {10.1038/s41586-022-04654-9},
  note = {URL: https://www.nature.com/articles/s41586-022-04654-9, accessed 2026-05-06. 13 targets, 15,000-100,000 designs each (~810,000 total candidates); for FGFR2/PDGFR hundreds of binders, for TIE2/CD3-delta fewer than 10 per ~100,000 library (~0.01\% raw); per-target final K_D 0.31 nM (IL-7Ra) to 860 nM (IGF1R).}
