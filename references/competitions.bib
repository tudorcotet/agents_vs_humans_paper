  author = {Zambaldi, Vinicius and La, David and Chu, Alexander E. and Patani, Harshnira and Danson, Amy E. and Kwan, Tristan O. C. and Frerix, Thomas and Schneider, Rosalia G. and Saxton, David and Thillaisundaram, Ashok and Wu, Zachary and Moraes, Isabel and Lange, Oskar and Papamakarios, George and Pacureanu, Alexandra and Cherepanov, Peter and Donoghue, Jared and Hassabis, Demis and Senior, Andrew W. and Jumper, John and Bridgland, Alex and Pritzel, Alexander},
