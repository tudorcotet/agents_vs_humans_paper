@article{Bennett2025,
  author = {Bennett, Nathaniel R. and Watson, Joseph L. and Ragotte, Robert J. and Borst, Andrew J. and See, D{\'e}Jena{\'e} L. and Weidle, Connor and Biswas, Riti and Yu, Yutong and Shrock, Ellen L. and Ault, Russell and Leung, Philip J. Y. and Huang, Buwei and Goreshnik, Inna and Tam, Joshua and Carr, Kenneth D. and Singer, Benedikt and Criswell, Cameron and Vafeados, Dionne and Garcia Sanchez, Mariana and Kim, Ho Min and Torres, Susana V{\'a}zquez and Chan, Sidney and Baker, David},
  title = {Atomically Accurate \textit{De Novo} Design of Antibodies with {RFdiffusion}},
  journal = {Nature},
  year = {2025},
  doi = {10.1038/s41586-025-09721-5},
  note = {URL: https://www.nature.com/articles/s41586-025-09721-5, accessed 2026-05-06. VHH design success rates of 0\%-2\% per target across 4 epitopes (RSV site III, influenza HA stem, SARS-CoV-2 RBD, C. difficile TcdB); 9,000 designs screened per target by yeast display. Initial K_D range tens to hundreds of nM (best HA stem 78 nM, TcdB 262 nM, RSV 1.4 uM, RBD 5.5 uM); OrthoRep affinity maturation drops to single-digit nM. AF3 ipTM > 0.6 enriches: only 9\% of designs pass that filter.}
}

