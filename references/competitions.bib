  archivePrefix = {arXiv},
  note = {URL: https://arxiv.org/abs/2409.08022, accessed 2026-05-06. 7 targets, hit rates 9\%-88\% (BHRF1 88\%, IL-7Ra 24.5\%, PD-L1 9.6\%, TrkA 9.6\%, IL-17A 14.3\%, VEGF-A 33\%, SC2RBD 8.5\%; 8th target TNF-alpha 0\%); 30-94 designs tested per target by yeast display. Best K_D 80 pM (IL-7Ra). Direct head-to-head with RFdiffusion designs gave AlphaProteo 16\% on IL-7Ra vs RFdiffusion 16.8\% (re-measured).}
