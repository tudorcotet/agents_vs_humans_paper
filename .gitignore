# macOS / editor
.DS_Store
*.swp
.idea/
.vscode/

# Python
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/
*.egg-info/
.venv/
.python-version

# uv
uv.lock.local

# Outputs that should be reproducible — keep them out of git, regenerate with `make analysis-all`.
# Curated outputs (the report.md and headline JSON we ship with the paper) ARE checked in;
# the broad `analyses/**/scratch/` carve-out below is what we ignore.
analyses/**/scratch/
analyses/**/_scratch/

# Figures: keep `figures/paper/` in git, ignore `figures/exploration/`.
figures/exploration/
figures/**/*.tmp.*

# Paper build outputs (Design B: only sections/*.md and figures/paper/*.svg are
# tracked; the build converts them on the fly). Regenerate with `mise run paper:build`.
paper/sections/*.tex
paper/paper.pdf
figures/paper/pdf/
# latexmk aux + the intermediate main.pdf before it's renamed to paper.pdf
paper/main.pdf
paper/*.aux
paper/*.bbl
paper/*.blg
paper/*.fdb_latexmk
paper/*.fls
paper/*.log
paper/*.out
paper/sections/*.aux

# Per-collaborator scratch
analyses/*/notebooks/.ipynb_checkpoints/

# Large derived intermediates (regenerate from data/designs.parquet)
# NOTE: do NOT ignore data/structures/, data/metrics/, data/sensorgrams/,
# data/images/ — those live in Git LFS and ship with the repo. Only true
# scratch/derived dirs go here.
data/folding/
data/_cache/

# Scratch CIFs from local re-folding runs — never commit these.
*.tmp.cif

# Git LFS local cache (some setups create this; harmless to ignore).
.lfs-cache/

# Secrets / local config
.env
.env.local
.envrc
*.pem
.doppler.yaml

# Local tooling / scratch (not committed)
.tools/
.firecrawl/

# Internal Adaptyv-only docs (URLs, Doppler paths, internal endpoint names).
# Lives outside the public release; the scripts read everything from env vars.
docs/INTERNAL.md
.env.adaptyv

# Runtime logs from background poll / rerun loops — never source.
.poll.log
.proteintyper.log

# Derivative intermediates of designs.csv. Every scalar in these files now
# lives on designs.csv (wide format). The PAE matrices under
# data/metrics/pae/ stay tracked — they're residue × residue payloads,
# not scalar.
data/grand_metrics.csv
data/metrics/proteintyper/
data/metrics/boltz2/
data/metrics/protenix/
data/metrics/chai/
data/metrics/af2m/
data/metrics/esm_pll/
data/metrics/netsolp/
data/metrics/saprot/
data/metrics/prodigy_boltz2/
data/metrics/prodigy_protenix/
data/metrics/prodigy_chai/
data/metrics/prodigy_af2m/
data/metrics/destress_boltz2/
data/metrics/destress_protenix/
data/metrics/destress_chai/
data/metrics/destress_af2m/
